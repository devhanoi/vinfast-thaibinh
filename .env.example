# ─── Database (Neon Postgres) ────────────────────────────────────────────────
# Pooled connection (cho app runtime). Bắt đầu bằng postgres://.
DATABASE_URL=
# Direct (non-pooled) connection cho prisma migrate (port 5432, không qua pgbouncer).
DIRECT_DATABASE_URL=

# ─── NextAuth v5 (Auth.js) ───────────────────────────────────────────────────
# Generate bằng: openssl rand -base64 32
NEXTAUTH_SECRET=
# Production để URL gốc, dev mặc định http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# ─── Admin seed (chạy 1 lần qua prisma/seed.ts) ──────────────────────────────
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ─── Storage adapter ─────────────────────────────────────────────────────────
# Switch backend: "r2" hoặc "s3". Service code không cần biết.
STORAGE_PROVIDER=r2

# Cloudflare R2 (dùng khi STORAGE_PROVIDER=r2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# AWS S3 (dùng khi STORAGE_PROVIDER=s3)
S3_REGION=ap-southeast-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_PUBLIC_BASE_URL=

# ─── Analytics / SEO verification (public) ───────────────────────────────────
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GSC_VERIFICATION=
